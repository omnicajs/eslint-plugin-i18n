{
  "name": "@omnicajs/eslint-plugin-i18n",
  "version": "1.0.0",
  "description": "OmnicaJS wrapper for @intlify/eslint-plugin-vue-i18n",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "node --eval \"fs.rmSync('dist', { recursive: true, force: true })\" && tsc --project tsconfig.build.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "npm run build && vitest run",
    "test:coverage": "npm run build && vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "debug": "^4.3.4",
    "globals": "^16.0.0"
  },
  "peerDependencies": {
    "eslint": "^8.0.0 || ^9.0.0-0 || ^10.0.0",
    "jsonc-eslint-parser": "^2.3.0 || ^3.0.0",
    "vue-eslint-parser": "^10.0.0",
    "yaml-eslint-parser": "^1.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/debug": "^4.1.12",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^4.1.3",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.2.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
